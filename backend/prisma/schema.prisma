// Prisma schema - Home-centric architecture

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================
// USER (ONLY OWNS HOMES)
// =====================
model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  homes        Home[]

  @@map("users")
}

// =====================
// HOME (CORE ENTITY)
// =====================
model Home {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String?
  location  String?
  createdAt DateTime @default(now()) @map("created_at")

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  devices        Device[]
  preferences    Preference[]
  alerts         Alert[]
  energyGoals    EnergyGoal[]
  energyScores   EnergyScore[]
  tips           Tip[]
  achievements   UserAchievement[]

  @@map("homes")
}

// =====================
// DEVICES
// =====================
model Device {
  id                 String              @id @default(uuid()) @db.Uuid
  homeId             String?             @map("home_id") @db.Uuid
  name               String?
  deviceType         String?             @map("device_type")
  createdAt          DateTime            @default(now()) @map("created_at")

  home               Home?               @relation(fields: [homeId], references: [id], onDelete: SetNull)
  detectedAppliances DetectedAppliance[]

  @@map("devices")
}

model DetectedAppliance {
  id             String    @id @default(uuid()) @db.Uuid
  deviceId       String    @map("device_id") @db.Uuid
  applianceName  String?   @map("appliance_name")
  estimatedPower Float?    @map("estimated_power")
  detectedAt     DateTime? @map("detected_at")

  device         Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@map("detected_appliances")
}

// =====================
// PREFERENCES (PER HOME)
// =====================
model Preference {
  id                  String   @id @default(uuid()) @db.Uuid
  homeId              String   @map("home_id") @db.Uuid
  maxPowerThreshold   Float?   @map("max_power_threshold")
  nightThreshold      Float?
  pricePerKwh         Float?   @map("price_per_kwh")
  currency            String?
  billingStart        Int?     @map("billing_start")
  enableNotifications Boolean? @default(true) @map("enable_notifications")
  createdAt           DateTime? @default(now()) @map("created_at")

  home                Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("preferences")
}

// =====================
// ALERTS (PER HOME)
// =====================
model Alert {
  id        String   @id @default(uuid()) @db.Uuid
  homeId    String   @map("home_id") @db.Uuid
  type      String?
  message   String?
  isRead    Boolean? @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  home      Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

// =====================
// ENERGY GOALS
// =====================
model EnergyGoal {
  id            String   @id @default(uuid()) @db.Uuid
  homeId        String   @map("home_id") @db.Uuid
  dailyLimitKwh Float?   @map("daily_limit_kwh")
  createdAt     DateTime @default(now()) @map("created_at")

  home          Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("energy_goals")
}

// =====================
// ENERGY SCORES
// =====================
model EnergyScore {
  id      String    @id @default(uuid()) @db.Uuid
  homeId  String    @map("home_id") @db.Uuid
  score   Int?
  date    DateTime? @db.Date

  home    Home      @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@unique([homeId, date])
  @@map("energy_scores")
}

// =====================
// ACHIEVEMENTS
// =====================
model Achievement {
  id               String            @id @default(uuid()) @db.Uuid
  name             String?
  description      String?

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid()) @db.Uuid
  homeId        String      @map("home_id") @db.Uuid
  achievementId String      @map("achievement_id") @db.Uuid
  earnedAt      DateTime    @default(now()) @map("earned_at")

  home          Home        @relation(fields: [homeId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@map("user_achievements")
}

// =====================
// TIPS
// =====================
model Tip {
  id        String   @id @default(uuid()) @db.Uuid
  homeId    String   @map("home_id") @db.Uuid
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  home      Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("tips")
}
