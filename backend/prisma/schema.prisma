// Prisma schema - Home-centric architecture

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =====================
// USER (ONLY OWNS HOMES)
// =====================
model User {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  homes        Home[]

  @@map("users")
}

// =====================
// HOME (CORE ENTITY)
// =====================
model Home {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String?
  location  String?
  createdAt DateTime @default(now()) @map("created_at")
  totalScore Int     @default(0) @map("total_score")
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  devices        Device[]
  preferences    Preference[]
  alerts         Alert[]
  energyGoals    EnergyGoal[]
  energyScores   EnergyScore[]
  tips           Tip[]
  achievements   UserAchievement[]

  @@map("homes")
}

// =====================
// DEVICES
// =====================
model Device {
  id                 String              @id @default(uuid()) @db.Uuid
  homeId             String?             @map("home_id") @db.Uuid
  name               String?
  deviceType         String?             @map("device_type")
  createdAt          DateTime            @default(now()) @map("created_at")

  home               Home?               @relation(fields: [homeId], references: [id], onDelete: SetNull)

  @@map("devices")
}

// =====================
// PREFERENCES (PER HOME)
// =====================
model Preference {
  id                  String   @id @default(uuid()) @db.Uuid
  homeId              String   @map("home_id") @db.Uuid
  maxPowerThreshold   Float?   @map("max_power_threshold")
  nightThreshold      Float?
  pricePerKwh         Float?   @map("price_per_kwh")
  currency            String?
  billingStart        Int?     @map("billing_start")
  enableNotifications Boolean? @default(true) @map("enable_notifications")
  createdAt           DateTime? @default(now()) @map("created_at")

  home                Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("preferences")
}

// =====================
// ALERTS (PER HOME)
// =====================
model Alert {
  id        String   @id @default(uuid()) @db.Uuid
  homeId    String   @map("home_id") @db.Uuid
  type      String?  // 'info' | 'warning' | 'critical'
  ruleType  String?  @map("rule_type") // 'overvoltage' | 'maxPower' | etc.
  message   String?
  metadata  Json?    // JSON field for rule-specific context (power, threshold, etc.)
  isRead    Boolean? @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  home      Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("alerts")
}

// =====================
// ENERGY GOALS
// =====================

model EnergyGoal {
  id                  String   @id @default(uuid()) @db.Uuid
  homeId              String   @map("home_id") @db.Uuid
  type                String   // 'daily' | 'weekly' | 'monthly'
  targetValue         Float    // e.g., kWh or cost amount
  targetMetric        String   // 'energy' | 'cost' | 'power'
  label               String?  // user-friendly label
  duration            Int      @default(1)         // number of periods (e.g. 3 for "3 days")
  endDate             DateTime @map("end_date")    // goal deadline = createdAt + duration * periodMs
  createdAt           DateTime @default(now()) @map("created_at")
  status              String   @default("active") // 'active' | 'achieved' | 'missed'
  home                Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@unique([homeId, type, targetMetric])
  @@map("energy_goals")
}

// =====================
// ENERGY SCORES
// =====================
model EnergyScore {
  id      String   @id @default(uuid()) @db.Uuid
  homeId  String   @map("home_id") @db.Uuid
  score   Int      @default(0)
  type    String   @default("goal")  // 'goal' | 'achievement'
  label   String?                    // why the score was awarded (e.g., "Daily energy goal completed")
  date    DateTime @default(now())   // exact timestamp of award
  isRead  Boolean  @default(false)   @map("is_read")

  home    Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@map("energy_scores")
}

// =====================
// ACHIEVEMENTS
// =====================
model Achievement {
  id               String            @id @default(uuid()) @db.Uuid
  name             String?
  description      String?
  lucideIconName  String?          @map("lucide_icon_name") // e.g., 'Trophy', 'Star'
  scoreValue       Int?             @map("score_value") // How much score this achievement is worth
  userAchievements UserAchievement[]
  isRead           Boolean?         @default(false) @map("is_read")

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(uuid()) @db.Uuid
  homeId        String      @map("home_id") @db.Uuid
  achievementId String      @map("achievement_id") @db.Uuid
  earnedAt      DateTime    @default(now()) @map("earned_at")
  isRead       Boolean?   @default(false) @map("is_read")
  home          Home        @relation(fields: [homeId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([homeId, achievementId])
  @@map("user_achievements")
}

// =====================
// TIPS
// =====================
model Tip {
  id               String   @id @default(uuid()) @db.Uuid
  homeId           String   @map("home_id") @db.Uuid
  imageUrls        String[] @map("image_urls")           // Scraped Google image URLs (up to 5)
  title            String?                               // Tip title (max 6 words)
  description      String?                               // Actionable explanation (max 2 sentences)
  categoryTag      String?  @map("category_tag")         // Category: 'Lighting', 'HVAC', 'Appliances', 'Habits'
  estimatedSavings String?  @map("estimated_savings")    // e.g., '~5% savings'
  sourceDeviceId   String?  @map("source_device_id") @db.Uuid
  metadata         Json?                                 // Extra AI response context or debugging info
  createdAt        DateTime @default(now()) @map("created_at")
  generatedAt      DateTime @default(now()) @map("generated_at")

  home             Home     @relation(fields: [homeId], references: [id], onDelete: Cascade)

  @@index([homeId, generatedAt])
  @@index([homeId, createdAt])
  @@map("tips")
}
